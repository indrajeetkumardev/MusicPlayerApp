@model MusicBaseApp.Models.SongUploadViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Upload Song</title>
    <style>
        body { font-family: Arial, sans-serif; max-width: 500px; margin: 40px auto; }
        label { display: block; margin-top: 12px; font-weight: bold; }
        input[type=text], input[type=file] { width: 100%; padding: 6px; margin-top: 4px; }
        button { margin-top: 16px; padding: 8px 16px; }
        .success { color: green; margin-top: 12px; }
        .error { color: red; margin-top: 4px; }
    </style>
</head>
<body>
    <h2>Upload Song</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="success">@TempData["SuccessMessage"]</div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="error">
            <ul>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <form asp-action="Upload" asp-controller="Admin" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <label asp-for="Title">Song Title</label>
        <input asp-for="Title" type="text" />

        <label asp-for="Artist">Artist Name</label>
        <input asp-for="Artist" type="text" />

        <label asp-for="Mp3File">MP3 File</label>
        <input asp-for="Mp3File" type="file" accept=".mp3" />

        <label asp-for="CoverImage">Cover Image</label>
        <input asp-for="CoverImage" type="file" accept=".jpg,.jpeg,.png" />

        <button type="submit">Upload</button>
    </form>
</body>
</html>
